# OS files
.DS_Store
Thumbs.db

# Editor settings (machine-specific)
.vscode/settings.json

# R files
.Rproj.user
.Rhistory
.RData
.Ruserdata

# Quarto cache
/.quarto/
**/*.quarto_ipynb
notebooks/*.out.ipynb

# LaTeX intermediate files (keep only final outputs)
index.log
index.aux
index.out
index.bbl
index.blg

# Python cache
__pycache__/
*.pyc

# Virtual environment (managed by uv)
.venv/

# Old output directories (no longer used)
_manuscript/
index-meca.zip

# REGION extension format-resources (auto-copied to root during render).
